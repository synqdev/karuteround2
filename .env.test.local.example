# Copy this to .env.test.local and fill in your TEST Supabase project values.
# NEVER use production credentials here.
NEXT_PUBLIC_SUPABASE_URL=https://[TEST-PROJECT-ID].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[test-anon-key]
SUPABASE_SERVICE_ROLE_KEY=[test-service-role-key]
# OpenAI key intentionally absent — always mocked in tests
